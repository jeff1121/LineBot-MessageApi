# LINE Messaging API 設定 (選填：如需驗證簽章或自動回覆訊息請設定)
LINE_CHANNEL_ID=your_channel_id_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# 簽章驗證開關 (true / false，若設為 true 且有 CHANNEL_SECRET 會驗證 X-Line-Signature)
ENABLE_SIGNATURE_CHECK=false

# 伺服器啟動設定
HOST=0.0.0.0
PORT=3000
